def generate_briefing(binance, mf=None, ib=None,
                      etf=None, cme=None, session="ondemand"):
    try:
        client = anthropic.Anthropic(api_key=get_env("ANTHROPIC_API_KEY"))
        prompt = build_prompt(binance, mf or {}, ib or {},
                              etf or {}, cme or {}, session)
        logger.info(f"Claude API 调用 | 会话: {session}")
        msg = client.messages.create(
            model="claude-sonnet-4-5",
            max_tokens=2500,
            messages=[{"role": "user", "content": prompt}]
        )
        result = msg.content[0].text
        logger.info(f"简报生成完成（{len(result)} 字）[{session}]")
        return result
    except Exception as e:
        logger.error(f"Claude API 失败: {e}")
        return f"AI 分析生成失败：{e}"
