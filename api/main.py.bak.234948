"""
BTC 实时数据面板 · FastAPI 后端  v5.0
三大盘口 IB / VP / MP / ETF / 清算 实时数据
新增：历史数据存储层（SQLite）
  - 5分钟快照：价格/成交量/OI/Funding/CB溢价
  - 每日存档：IB/VP/MP/ETF/清算统计
"""
import asyncio, importlib, json, logging, sqlite3, sys
